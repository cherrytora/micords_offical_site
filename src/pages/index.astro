---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import { getEntry } from 'astro:content';

const APP_URL = 'https://micords.web.app/';
const home = await getEntry('pages', 'home');
const {
  heroTitle, heroSubtitle, ctaPrimary,
  painPointsTitle, painPoints,
  featuresTitle, featuresSubtitle, features,
  storyTitle, storyP1, storyP2, storyP3,
  ctaTitle, ctaSubtitle, ctaButton,
} = home.data;
---

<BaseLayout title="首頁" description="Micords — 讓對貓的愛，更有跡可循">
  <Nav />

  <!-- Hero -->
  <section class="hero-gradient pt-32 pb-20 px-6">
    <div class="max-w-6xl mx-auto grid md:grid-cols-2 gap-12 items-center">
      <div>
        <h1 class="text-4xl md:text-5xl font-bold leading-tight mb-6 text-slate-900">
          {heroTitle}
        </h1>
        <p class="text-lg text-slate-600 mb-8 leading-relaxed">
          {heroSubtitle}
        </p>
        <!-- 服務下載連結 -->
        <div class="flex flex-wrap gap-4">
          <a
            href={APP_URL}
            target="_blank"
            rel="noopener noreferrer"
            class="bg-brand-orange text-white px-8 py-4 rounded-2xl font-bold text-lg shadow-lg shadow-orange-200 hover:scale-105 transition"
          >
            {ctaPrimary}
          </a>
          <a
            href={`${import.meta.env.BASE_URL.replace(/\/$/, '')}/tutorial`}
            class="border-2 border-brand-orange text-brand-orange px-8 py-4 rounded-2xl font-bold text-lg hover:bg-orange-50 transition"
          >
            查看教學
          </a>
        </div>

      </div>

      <div class="relative">
        <div class="bg-orange-200 w-full h-[400px] rounded-3xl overflow-hidden shadow-2xl border-4 border-white">
          <img
            src="https://images.unsplash.com/photo-1514888286974-6c03e2ca1dba?auto=format&fit=crop&q=80&w=800"
            alt="可愛貓咪"
            class="w-full h-full object-cover"
          />
        </div>
        <div class="absolute -bottom-4 -right-4 bg-white p-4 rounded-2xl shadow-xl border border-orange-50">
          <div class="flex items-center gap-2">
            <span class="w-2 h-2 bg-green-400 rounded-full animate-pulse"></span>
            <span class="text-xs font-bold text-slate-500">系統即時守護中</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- 痛點共鳴 -->
  <section class="py-24 px-6 bg-white">
    <div class="max-w-4xl mx-auto text-center">
      <h2 class="text-3xl font-bold mb-16 text-slate-900">{painPointsTitle}</h2>
      <div class="grid md:grid-cols-3 gap-8">
        {painPoints.map(({ icon, text }) => (
          <div class="p-6">
            <div class="text-4xl mb-4 text-orange-400">{icon}</div>
            <p class="text-slate-600 leading-relaxed font-medium">{text}</p>
          </div>
        ))}
      </div>
      <div class="mt-12 inline-block px-8 py-4 bg-brand-cream rounded-full text-brand-orange font-medium">
        別擔心，這些細微的擔憂，從今天起交給 Micords 來幫你記得。
      </div>
    </div>
  </section>

  <!-- 核心功能 -->
  <section class="py-24 px-6 bg-brand-cream">
    <div class="max-w-6xl mx-auto">
      <div class="text-center mb-16">
        <h2 class="text-3xl font-bold mb-4">{featuresTitle}</h2>
        <p class="text-slate-500 italic">{featuresSubtitle}</p>
      </div>
      <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-6">
        {features.map(({ icon, title, desc }) => (
          <div class="bg-white p-8 rounded-3xl shadow-sm border border-orange-50 hover:-translate-y-1 transition-transform duration-300">
            <div class="w-12 h-12 bg-orange-100 rounded-2xl flex items-center justify-center text-2xl mb-6">
              {icon}
            </div>
            <h3 class="font-bold text-lg mb-3">{title}</h3>
            <p class="text-slate-500 text-sm leading-relaxed">{desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- App 視覺化展示 -->
  <section class="py-24 px-6 bg-white overflow-hidden border-b border-orange-50">
    <div class="max-w-6xl mx-auto flex flex-col md:flex-row items-center gap-16">
      <!-- 手機示意圖 -->
      <div class="md:w-1/2 order-2 md:order-1">
        <div class="relative mx-auto border-[10px] border-slate-900 rounded-[3rem] h-[600px] w-[300px] shadow-2xl overflow-hidden bg-white">
          <div class="bg-brand-orange h-24 p-6 text-white pt-12">
            <div class="w-12 h-1 bg-white/20 rounded-full mx-auto -mt-2 mb-4"></div>
          </div>
          <div class="p-6">
            <p class="text-xs font-bold text-slate-400 mb-4 tracking-widest uppercase text-center">Health Trend</p>
            <div class="h-44 w-full relative mb-8 flex items-center justify-center">
              <svg viewBox="0 0 200 100" class="w-full h-full overflow-visible">
                <line x1="0" y1="20" x2="200" y2="20" stroke="#f1f5f9" stroke-width="1.5" />
                <line x1="0" y1="50" x2="200" y2="50" stroke="#f1f5f9" stroke-width="1.5" />
                <line x1="0" y1="80" x2="200" y2="80" stroke="#f1f5f9" stroke-width="1.5" />
                <path
                  d="M0,75 Q30,70 50,45 T100,55 T150,25 T200,35"
                  fill="none"
                  stroke="#FF8D41"
                  stroke-width="4"
                  stroke-linecap="round"
                  class="line-chart-path"
                />
                <circle cx="150" cy="25" r="5" fill="#FF8D41" />
                <circle cx="150" cy="25" r="8" fill="#FF8D41" fill-opacity="0.2" class="animate-pulse" />
              </svg>
            </div>
            <div class="space-y-4">
              <div class="bg-slate-50 p-4 rounded-xl flex justify-between items-center border border-slate-100">
                <span class="text-sm font-medium text-slate-600">BUN 血檢值</span>
                <span class="text-sm text-brand-orange font-bold">28 mg/dL</span>
              </div>
              <div class="bg-slate-50 p-4 rounded-xl flex justify-between items-center border border-slate-100">
                <div class="flex flex-col">
                  <span class="text-sm font-medium text-slate-600">下次驅蟲提醒</span>
                  <span class="text-[10px] text-slate-400">重要事件</span>
                </div>
                <span class="text-xs bg-orange-100 text-brand-orange px-2 py-1 rounded-full font-bold">12 天後</span>
              </div>
            </div>
          </div>
        </div>
      </div>

      <div class="md:w-1/2 order-1 md:order-2">
        <h2 class="text-3xl font-bold mb-6 text-slate-900">健康，是一場溫柔的長跑。</h2>
        <p class="text-lg text-slate-600 leading-relaxed mb-6">
          數據不應該是生硬的字，而是安心的保證。透過 Micords 視覺化的圖表設計，複雜的生理變化變得簡單直覺。
        </p>
        <div class="space-y-4">
          {[
            '看診提醒：回診時間不再遺忘',
            '吃藥通知：精確記錄每一次餵藥時間',
            '數據圖表：一看就懂的體重與血檢變化趨勢',
          ].map((text) => (
            <div class="flex items-start gap-4">
              <div class="mt-1 text-brand-orange">✦</div>
              <p class="text-slate-600 font-medium">{text}</p>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- 品牌小故事 -->
  <section class="py-24 px-6 bg-white" id="story">
    <div class="max-w-3xl mx-auto text-center">
      <p class="text-brand-orange font-bold tracking-widest uppercase text-sm mb-4">Our Story</p>
      <h2 class="text-3xl font-bold mb-8 text-slate-900">{storyTitle}</h2>
      <div class="relative">
        <img
          src="https://images.unsplash.com/photo-1574158622682-e40e69881006?auto=format&fit=crop&q=80&w=400"
          alt="睡覺的貓"
          class="w-32 h-32 rounded-full mx-auto object-cover border-4 border-orange-100 shadow-xl mb-8"
        />
      </div>
      <div class="text-slate-600 leading-relaxed space-y-4 text-left max-w-2xl mx-auto">
        <p>{storyP1}</p>
        <p>{storyP2}</p>
        <p>{storyP3}</p>
      </div>
      <p class="mt-8 text-slate-400 font-medium tracking-widest uppercase text-sm">For every beloved cat</p>
      <p class="text-[10px] text-slate-300 mt-1 tracking-widest">DESIGNED BY RILA LAB</p>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-24 px-6 bg-brand-cream text-center">
    <div class="max-w-3xl mx-auto">
      <h2 class="text-4xl font-bold mb-6 text-slate-900">{ctaTitle}</h2>
      <p class="text-xl text-slate-600 mb-10 leading-relaxed">
        {ctaSubtitle}
      </p>
      <a
        href={APP_URL}
        target="_blank"
        rel="noopener noreferrer"
        class="inline-block bg-brand-orange text-white px-12 py-5 rounded-2xl font-bold text-xl shadow-2xl shadow-orange-200 hover:scale-105 transition"
      >
        {ctaButton}
      </a>
    </div>
  </section>

  <Footer />
</BaseLayout>
